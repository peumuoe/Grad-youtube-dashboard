YOUTUBE_API_KEY=your_youtube_data_api_key
OUTPUT_FORMAT=csv
LOG_LEVEL=INFO
TRANSCRIPT_LANGUAGES=ko,en
TRANSCRIPT_MAX_VIDEOS_PER_RUN=300
TRANSCRIPT_SAVE_EVERY=25
TRANSCRIPT_MAX_CONSECUTIVE_IP_BLOCKS=10
TRANSCRIPT_RETRY_NONE_ROWS=0
ENABLE_STT=0
STT_MODEL_SIZE=tiny
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=1
AUDIO_CACHE_DIR=data/raw/audio_cache
KEEP_DOWNLOADED_AUDIO=0
